{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paytec.ch/schemas/ecritf-v1.0.0.json",
  "title": "PayTec EFT/POS Terminal Interface Schema",
  "description": "JSON Schema for the PayTec ECR Interface messages. This schema defines all request and response messages for communication with PayTec EFT/POS terminals.",
  "version": "1.0.0",
  "$defs": {
    "TrmID": {
      "type": "string",
      "description": "Terminal identification, 8 alphanumeric characters.",
      "pattern": "^[A-Za-z0-9]{8}$",
      "examples": ["12345678"]
    },
    "IFDSerialNum": {
      "type": "string",
      "pattern": "^[A-Za-z0-9]{8}$",
      "description": "Interface device serial number.",
      "examples": ["ZPD00001"]
    },
    "LanguageCode": {
      "type": "string",
      "description": "Language code according to ISO 639-1 (e.g., 'de' for German, 'en' for English).",
      "pattern": "^[a-z]{2}$",
      "examples": ["de", "en", "fr", "it"]
    },
    "TrmStatus": {
      "type": "integer",
      "description": "Terminal status flags (bitwise combination): SHIFT_OPEN=0x01, CARD_DATA_AVAILABLE=0x02, BUSY=0x04, READER_SLOT_OCCUPIED=0x08, LOCKED=0x10, APPLICATION_SELECTED=0x20, WAITING_FOR_TRANSACTION_REQUEST=0x40, WAITING_FOR_APPLICATION_SELECTION=0x80, ONLINE_PROCESSING=0x100, PRINTER_UNAVAILABLE=0x200, OUT_OF_PAPER=0x400",
      "minimum": 0,
      "examples": [513]
    },
    "TrxFunction": {
      "type": "integer",
      "description": "Transaction function code: PURCHASE_WITH_CASHBACK=0x01 (1), CONFIRM_PHONE_AUTH_RESERVATION=0x04 (4), RESERVATION_ADJUSTMENT=0x08 (8), RESERVATION=0x10 (16), REVERSAL=0x20 (32), PURCHASE_MAIL_ORDERED=0x40 (64), AUTHORIZATION_PURCHASE=0x80 (128), PURCHASE_PHONE_ORDERED=0x100 (256), PURCHASE_FORCED_ACCEPTANCE=0x200 (512), PURCHASE_PHONE_AUTH=0x400 (1024), CREDIT=0x800 (2048), CASH_ADVANCE=0x1000 (4096), TIP=0x2000 (8192), PURCHASE_RESERVATION=0x4000 (16384), PURCHASE=0x8000 (32768), BALANCE_INQUIRY=0x20000 (131072), ACTIVATE_CARD=0x800000 (8388608), LOAD=0x1000000 (16777216), CANCEL_RESERVATION=0x2000000 (33554432), ACCOUNT_VERIFICATION=0x4000000 (67108864)",
      "enum": [1, 4, 8, 16, 32, 64, 128, 256, 512, 1024, 2048, 4096, 8192, 16384, 32768, 131072, 8388608, 16777216, 33554432, 67108864],
      "examples": [32768]
    },
    "TrxFunctions": {
      "type": "integer",
      "description": "Supported transaction functions (bitwise combination of TrxFunction values)",
      "minimum": 0,
      "examples": [182433]
    },
    "TrxResult": {
      "type": "integer",
      "description": "Transaction result: 0=Approved, 1=Declined, 2=Referred (phone auth needed), 3=Aborted",
      "enum": [0, 1, 2, 3],
      "examples": [0]
    },
    "TrxResultExtended": {
      "type": "integer",
      "description": "Extended transaction result code: 0-899=TRX_RESULT_APPROVED, 900-999=TRX_RESULT_REFERRED, 1000-9999=TRX_RESULT_DECLINED, 10000-49999=TRX_RESULT_ABORTED. Specific codes: 10014=TRX_RESULT_ABORTED_MATCHED_SURROGATE_PAN, 10017=TRX_RESULT_ABORTED_SCHEDULED_TASK_PENDING (returned 1 minute after starting an authorization purchase transaction when no card is presented and a scheduled task is due; ECR should wait at least 20 seconds and for TrmStatus BUSY flag to clear before restarting)",
      "minimum": 0,
      "examples": [100]
    },
    "TrxReqFlags": {
      "type": "integer",
      "description": "Transaction request flags: 0x01=Start silently, 0x04=Report unknown NFC UIDs in status, 0x08=Abort silently on unknown NFC",
      "minimum": 0,
      "examples": [5]
    },
    "TrxAbortFlags": {
      "type": "integer",
      "description": "Transaction abort flags: 0x01=Abort silently without notifying cardholder",
      "minimum": 0,
      "examples": [1]
    },
    "POSEntryMode": {
      "type": "integer",
      "description": "POS entry mode: 0=Unknown, 1=Manual, 3=Barcode, 4=OCR, 5=ICC, 6=ICC PAN Retrieval, 20=Reference, 21=BLE, 90=Magstripe, 91-93=Magstripe fallback, 97=Contactless EMV, 98=Contactless magstripe, 99=Contactless PAN Retrieval, 1001=Merchant presented QR Code",
      "minimum": 0,
      "examples": [97]
    },
    "DeviceCommandCode": {
      "type": "integer",
      "description": "Device command: 1=Eject card, 2=Force eject, 501=Reboot, 502=SW update, 511=Remote maintenance, 521=Ship logs, 1001/1002=Language dialog on/off, 2001=Show idle, 2002=Present card message, 2601=Scan barcode, 2602=Abort barcode scanning",
      "enum": [1, 2, 501, 502, 511, 521, 1001, 1002, 2001, 2002, 2601, 2602],
      "examples": [2601]
    },
    "ReceiptType": {
      "type": "integer",
      "description": "Receipt type: 1=Transaction, 2=Transaction copy, 11=Activation, 13=Deactivation, 21=Final balance, 23=Submission, 25=Transmission, 41=Configuration, 43=Initialization, 111=DCC offer, 112=DCC rates",
      "enum": [1, 2, 11, 13, 21, 23, 25, 41, 43, 111, 112],
      "examples": [1]
    },
    "ReceiptFlags": {
      "type": "integer",
      "description": "Receipt flags: 0x01=More data available, 0x04=Double height, 0x10=Inverse, 0x20=PNG image (data is base64-encoded PNG)",
      "minimum": 0,
      "examples": [16]
    },
    "ReportType": {
      "type": "integer",
      "description": "Report type: 1=Shift sum, 2=Accounting period sum, 1001=Open petrol authorizations",
      "enum": [1, 2, 1001],
      "examples": [1]
    },
    "ReportFlags": {
      "type": "integer",
      "description": "Report flags: 1=More entries available",
      "minimum": 0
    },
    "FinancialCounterType": {
      "type": "integer",
      "description": "Financial counter type: 0=Debit, 1=Credit, 2=Debit reversal, 3=Credit reversal, 4=Reservation, 5=Other Non-financial",
      "enum": [0, 1, 2, 3, 4, 5],
      "examples": [1]
    },
    "PrinterStatus": {
      "type": "integer",
      "description": "Printer status flags: 0x00=OK, 0x01=No paper, 0x02=Jammed, 0x04=Overheat, 0x08=Other error, 0x10=Buffer full, 0x20=Timeout, 0x40=Power failure",
      "minimum": 0,
      "examples": [0]
    },
    "BatchCaptureFlags": {
      "type": "integer",
      "description": "Batch capture flags (bitwise combination): 0x01=Manual (include last transaction), 0x02=No submission, 0x04=No transmission",
      "minimum": 0
    },
    "DialogFlags": {
      "type": "integer",
      "description": "Dialog flags (bitwise combination): 0x01=Leave on screen, 0x02=Display input resource, 0x04=Hide input, 0x08=Use attendant language, 0x10=Hide OK on empty signature, 0x20=Allow show input, 0x40=Replaces welcome",
      "minimum": 0
    },
    "DialogIcon": {
      "type": "integer",
      "description": "Dialog icon: 1=Please wait, 2=Insert card, 3=Remove card, 4=Approved, 5=Declined, 6=Question, 7=Mobile",
      "enum": [1, 2, 3, 4, 5, 6, 7]
    },
    "DialogResource": {
      "type": "integer",
      "description": "Dialog resource: 1010=Free text, 1060=Free text with brands, 10001=Please wait, 10005=Signature please, 10008=Select pump, 10009=Enter mileage, 10010=Enter further info, 15013=Free text with custom buttons",
      "enum": [1010, 1060, 10001, 10005, 10008, 10009, 10010, 15013]
    },
    "DialogResult": {
      "type": "integer",
      "description": "Dialog result: 1=OK, 2=Stop, 3=Timeout, 4=Cancelled, 5=Back, 6=Left button, 7=Right button",
      "enum": [1, 2, 3, 4, 5, 6, 7]
    },
    "InputType": {
      "type": "integer",
      "description": "Input type: 0=Empty (no input), 2=Unsigned numeric, 51=Numeric string, 52=Alphanumeric special, 101=Password, 151=E-signature",
      "enum": [0, 2, 51, 52, 101, 151]
    },
    "UIButtons": {
      "type": "integer",
      "description": "UI button flags (bitwise combination): 0x01=OK, 0x02=Cancel, 0x04=Clear, 0x08=Back, 0x10=Left, 0x20=Right",
      "minimum": 0
    },
    "ErrorCode": {
      "type": "integer",
      "description": "Error code; can be OS specific"
    },
    "Amount": {
      "type": "integer",
      "description": "Monetary amount in the currency's minor unit (e.g., cents for EUR/USD)",
      "minimum": 0,
      "examples": [1500]
    },
    "CurrencyCode": {
      "type": "integer",
      "description": "ISO 4217 numeric currency code",
      "minimum": 0,
      "maximum": 999,
      "examples": [756, 978, 840]
    },
    "CountryCode": {
      "type": "integer",
      "description": "ISO 3166 numeric country code",
      "minimum": 0,
      "maximum": 999,
      "examples": [756, 276, 840]
    },
    "Base64Binary": {
      "type": "string",
      "description": "Base64 encoded binary data",
      "contentEncoding": "base64"
    },
    "HexString": {
      "type": "string",
      "description": "Hexadecimal encoded string",
      "pattern": "^[0-9A-Fa-f]*$"
    },
    "DateYYMMDD": {
      "type": "string",
      "description": "Date in YYMMDD format",
      "pattern": "^[0-9]{6}$",
      "examples": ["210101"]
    },
    "DateYYYYMMDD": {
      "type": "string",
      "description": "Date in YYYYMMDD format",
      "pattern": "^[0-9]{8}$",
      "examples": ["20210101"]
    },
    "TimeHHMMSS": {
      "type": "string",
      "description": "Time in HHMMSS format",
      "pattern": "^[0-9]{6}$",
      "examples": ["120000"]
    },
    "AcqInfo": {
      "type": "object",
      "description": "Acquirer information",
      "properties": {
        "AcqID": {
          "type": "integer",
          "description": "Acquirer identifier"
        },
        "LastAcqInitDate": {
          "type": "string",
          "description": "Last acquirer initialization date"
        }
      },
      "additionalProperties": true
    },
    "NextScheduledTask": {
      "type": "object",
      "description": "Information about the next scheduled task",
      "required": ["TaskName", "NextRun"],
      "properties": {
        "TaskName": {
          "type": "string",
          "description": "Name of the scheduled task",
          "enum": ["CONFIG", "CONFIG_FORCED", "INIT", "INIT_FORCED", "SUBMISSION", "TRANSMISSION", "FINAL_BALANCE", "SW_UPDATE", "REBOOT", "AUTO_REVERSAL", "DECOMMISSIONING"]
        },
        "LastRun": {
          "type": "string",
          "description": "Local date/time when task was last performed: yyyy-MM-dd HH:mm:ss"
        },
        "NextRun": {
          "type": "string",
          "description": "Local date/time when task will be performed next: yyyy-MM-dd HH:mm:ss"
        },
        "AcqID": {
          "type": "integer",
          "description": "Acquirer Identifier (present if TaskName is INIT or INIT_FORCED)"
        }
      },
      "additionalProperties": true
    },
    "FinancialReportEntry": {
      "type": "object",
      "description": "Financial report entry",
      "required": ["Brand", "AID", "FinancialCounterType", "TrxCurrC", "TrxCount", "TotalAmount"],
      "properties": {
        "Brand": { "type": "string" },
        "AID": { "$ref": "#/$defs/Base64Binary" },
        "FinancialCounterType": { "$ref": "#/$defs/FinancialCounterType" },
        "TrxCurrC": { "$ref": "#/$defs/CurrencyCode" },
        "TrxCount": { "type": "integer" },
        "TotalAmount": { "$ref": "#/$defs/Amount" },
        "TipAmount": { "$ref": "#/$defs/Amount" },
        "DCCForeignCurrC": { "$ref": "#/$defs/CurrencyCode" },
        "DCCForeignAmount": { "$ref": "#/$defs/Amount" }
      },
      "additionalProperties": true
    },
    "TrxListReportEntry": {
      "type": "object",
      "description": "Transaction list report entry",
      "required": ["TrxSeqCnt", "TrxDate", "TrxTime"],
      "properties": {
        "TrxSeqCnt": { "type": "integer" },
        "TrxDate": { "$ref": "#/$defs/DateYYMMDD" },
        "TrxTime": { "$ref": "#/$defs/TimeHHMMSS" },
        "FinancialCounterType": { "$ref": "#/$defs/FinancialCounterType" },
        "TrxFunction": { "$ref": "#/$defs/TrxFunction" },
        "AuthReslt": { "type": "integer" },
        "TrxCurrC": { "$ref": "#/$defs/CurrencyCode" },
        "AmtAuth": { "$ref": "#/$defs/Amount" },
        "AppPANPrtAttendant": { "type": "string" }
      },
      "additionalProperties": true
    },
    "TrxDataChangeReason": {
      "type": "object",
      "description": "Transaction data change reason",
      "properties": {
        "TrxDataChangeReasonCode": { "type": "integer" },
        "MyOneDiscountCode": { "type": "integer", "description": "MyOne discount code" },
        "BonusCardBrandNumber": { "type": "integer", "description": "Bonus card brand number" }
      },
      "additionalProperties": true
    },
    "RecOrderRef": {
      "type": "object",
      "description": "Merchant order reference record",
      "properties": {
        "OrderID": {
          "type": "string",
          "description": "Merchant's order identifier (max 18 chars for ep2 7.x, 48 chars for ep2 >= 8.x)"
        }
      }
    },
    "ConnectRequest": {
      "type": "object",
      "description": "Request to connect to the terminal",
      "properties": {
        "TrmLng": { "$ref": "#/$defs/LanguageCode" },
        "PrinterWidth": {
          "type": "integer",
          "description": "Maximum number of characters to be printed on one line",
          "examples": [34, 40]
        },
        "SetTrxDataChangeReason": {
          "type": "array",
          "description": "Set of transaction data change reasons to activate",
          "items": { "$ref": "#/$defs/TrxDataChangeReason" }
        },
        "UnsolicitedReceipts": {
          "type": "integer",
          "description": "If true, every receipt generated by the terminal is forwarded as receipt response to the cash register",
          "enum": [0, 1]
        },
        "SuppressScheduledTasks": {
          "type": "integer",
          "description": "If true, no scheduled tasks (initializations, batch captures, etc.) shall be performed; also prevents standby/sleep mode",
          "enum": [0, 1]
        },
        "POSID": {
          "type": "string",
          "description": "Point of sale identifier"
        }
      },
      "additionalProperties": true
    },
    "ConnectResponse": {
      "type": "object",
      "description": "Response to connect request",
      "required": ["TrmLng", "IFDSerialNum", "SoftwareVersion", "PeSeqCnt", "ActSeqCnt"],
      "properties": {
        "TrmID": { "$ref": "#/$defs/TrmID" },
        "TrmLng": { "$ref": "#/$defs/LanguageCode" },
        "IFDSerialNum": { "$ref": "#/$defs/IFDSerialNum" },
        "SoftwareVersion": { "type": "integer" },
        "PeSeqCnt": { "type": "integer", "description": "Booking period sequence counter" },
        "ActSeqCnt": { "type": "integer", "description": "Activation/shift sequence counter" }
      },
      "additionalProperties": true
    },
    "StatusRequest": {
      "type": "object",
      "description": "Request terminal status"
    },
    "StatusResponse": {
      "type": "object",
      "description": "Terminal status response",
      "required": ["TrmStatus", "TrmLng", "ESigInd"],
      "properties": {
        "TrmStatus": { "$ref": "#/$defs/TrmStatus" },
        "TrmLng": { "$ref": "#/$defs/LanguageCode" },
        "IIN": { "type": "integer", "description": "Issuer Identification Number (first 6 digits of PAN)" },
        "ATR": { "$ref": "#/$defs/Base64Binary", "description": "Answer To Reset of the ICC" },
        "AID": { "$ref": "#/$defs/Base64Binary", "description": "Application Identification Number of currently selected application" },
        "AIDICC": { "$ref": "#/$defs/Base64Binary", "description": "Application Identification as read from the IC card" },
        "AppCurrC": { "$ref": "#/$defs/CurrencyCode", "description": "Application Currency Code from EMV card" },
        "AppCurrExp": { "type": "integer", "description": "Application Currency Exponent" },
        "Track2Data": { "$ref": "#/$defs/Base64Binary", "description": "Magstripe ISO track 2 data" },
        "Track3Data": { "$ref": "#/$defs/Base64Binary", "description": "Magstripe ISO track 3 data" },
        "UID": { "$ref": "#/$defs/Base64Binary", "description": "NFC Unique ID" },
        "ESigInd": { "type": "integer", "description": "E-Signature indicator (0 or 1)", "enum": [0, 1] },
        "LastReaderCleaningDate": { "type": "string", "description": "Local date/time of last cleaning: yyyy-MM-dd HH:mm:ss" },
        "SetAcqInfo": {
          "type": "array",
          "items": { "$ref": "#/$defs/AcqInfo" },
          "description": "Set of configured acquirer information"
        },
        "CardholderLng": { "$ref": "#/$defs/LanguageCode" },
        "NextScheduledTask": { "$ref": "#/$defs/NextScheduledTask" }
      },
      "additionalProperties": true
    },
    "ActivationRequest": {
      "type": "object",
      "description": "Request to activate the terminal (open shift)",
      "properties": {
        "AttendantName": { "type": "string" },
        "AttendantNumber": { "type": "integer" }
      },
      "additionalProperties": true
    },
    "ActivationResponse": {
      "type": "object",
      "description": "Activation response with terminal configuration",
      "required": ["TrmID", "TrmType", "TrmLng", "PeSeqCnt", "ActSeqCnt", "TrxSeqCnt", "TrxFunctions", "Currencies", "Brands"],
      "properties": {
        "TrmID": { "$ref": "#/$defs/TrmID" },
        "TrmType": {
          "type": "integer",
          "enum": [11, 12, 13, 14, 15, 16, 21, 22, 23, 24, 25, 26, 34, 35, 36],
          "description": "Terminal Type as defined in EMV Book 4, Annex A1"
        },
        "TrmLng": { "$ref": "#/$defs/LanguageCode" },
        "PeSeqCnt": {
          "type": "integer",
          "minimum": 0,
          "maximum": 99999999,
          "description": "Current booking period sequence counter"
        },
        "ActSeqCnt": {
          "type": "integer",
          "minimum": 0,
          "maximum": 99999999,
          "description": "Current activation sequence counter"
        },
        "TrxSeqCnt": {
          "type": "integer",
          "minimum": 0,
          "maximum": 99999999,
          "description": "Transaction sequence counter of the most recent transaction. If no transactions have been processed so far, the value 0 is used."
        },
        "TrmCntryC": { "$ref": "#/$defs/CountryCode" },
        "MctID": {
          "type": "string",
          "minLength": 15,
          "maxLength": 15,
          "description": "Merchant identifier"
        },
        "MctNameLoc": {
          "type": "string",
          "minLength": 1,
          "maxLength": 75,
          "description": "Merchant name and location"
        },
        "TrxFunctions": { "$ref": "#/$defs/TrxFunctions" },
        "Currencies": {
          "type": "array",
          "description": "Set of supported currencies",
          "items": { "$ref": "#/$defs/CurrencyCode" }
        },
        "Brands": {
          "type": "array",
          "description": "Set of supported card brands",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "DeactivationRequest": {
      "type": "object",
      "description": "Request to deactivate the terminal (close shift)"
    },
    "DeactivationResponse": {
      "type": "object",
      "description": "Deactivation response"
    },
    "TransactionRequest": {
      "type": "object",
      "description": "Request to perform a payment transaction",
      "required": ["TrxFunction"],
      "properties": {
        "TrxFunction": { "$ref": "#/$defs/TrxFunction" },
        "TrxCurrC": { "$ref": "#/$defs/CurrencyCode" },
        "AmtAuth": { "$ref": "#/$defs/Amount" },
        "AmtOther": {
          "$ref": "#/$defs/Amount",
          "description": "Cashback amount"
        },
        "AuthC": {
          "type": "string",
          "description": "Authorization code for phone-authorized transactions"
        },
        "AcqID": {
          "type": "integer",
          "description": "Acquirer identifier for reference-based transactions"
        },
        "TrxRefNum": {
          "type": "string",
          "description": "Original transaction reference for reference-based transactions"
        },
        "TrxSeqCntOri": {
          "type": "integer",
          "description": "Original transaction sequence counter"
        },
        "TrxReasonC": {
          "type": "string",
          "description": "Transaction reason code"
        },
        "PartialApprovalCap": {
          "type": "integer",
          "description": "Partial approval capability (0 or 1)",
          "enum": [0, 1]
        },
        "RecOrderRef": { "$ref": "#/$defs/RecOrderRef" },
        "DCCOrigDate": {
          "$ref": "#/$defs/DateYYYYMMDD",
          "description": "Original date of DCC rate quotation, used for refunds of DCC transactions"
        },
        "TextOnUnknownNFC": {
          "type": "string",
          "description": "Text to display for unknown NFC cards"
        },
        "SetActiveSurrogatePAN": {
          "type": "array",
          "items": { "$ref": "#/$defs/Base64Binary" },
          "description": "Surrogate PANs currently involved in a fuelling process (petrol). If any of these cards are presented, the transaction is immediately aborted with result TRX_RESULT_ABORTED_MATCHED_SURROGATE_PAN to let the fuel station print a receipt"
        },
        "TrxReqFlags": { "$ref": "#/$defs/TrxReqFlags" }
      },
      "additionalProperties": true
    },
    "TransactionResponse": {
      "type": "object",
      "description": "Transaction result. Warning: Additional fields may be added in future versions.",
      "required": ["TrxResult", "TrmID", "TrxResultExtended"],
      "properties": {
        "TrxResult": { "$ref": "#/$defs/TrxResult" },
        "TrmID": { "$ref": "#/$defs/TrmID" },
        "TrxResultExtended": { "$ref": "#/$defs/TrxResultExtended" },
        "Brand": { "type": "string", "description": "Card brand" },
        "AccountType": { "type": "integer", "description": "Account type" },
        "AcqID": { "type": "integer", "description": "Acquirer identifier" },
        "AID": { "$ref": "#/$defs/Base64Binary", "description": "Application identifier" },
        "AIDICC": { "$ref": "#/$defs/Base64Binary", "description": "AID as read from card" },
        "IIN": { "type": "integer", "description": "6-digit issuer identification number" },
        "AppExpDate": { "$ref": "#/$defs/DateYYMMDD", "description": "Application expiration date" },
        "AppPAN": { "$ref": "#/$defs/Base64Binary", "description": "Application Primary Account Number" },
        "AppPANPrtCardholder": { "type": "string", "description": "Masked PAN for cardholder" },
        "AppPANPrtAttendant": { "type": "string", "description": "Masked PAN for attendant" },
        "AppPANEnc": { "type": "string", "description": "Encrypted PAN for manual resubmission" },
        "StatKeyPANRctInd": { "$ref": "#/$defs/Base64Binary", "description": "EP2 Static Key PAN Receipt Index, needed for receipt from ep2 version 6.0.0. With ep2 >= 7.0.0 this field contains <ep2:KeyPANRctInd>" },
        "KeyPANRctDOLInd": { "$ref": "#/$defs/Base64Binary", "description": "Key PAN Receipt DOL Indicator" },
        "AmtAuth": { "$ref": "#/$defs/Amount", "description": "Authorized amount" },
        "AmtOther": { "$ref": "#/$defs/Amount", "description": "Cashback amount" },
        "TrxAmt": { "$ref": "#/$defs/Amount", "description": "Final transaction amount" },
        "TipAmt": { "$ref": "#/$defs/Amount", "description": "Tip amount" },
        "AuthC": { "type": "string", "description": "Authorization code" },
        "ARC": { "type": "string", "description": "Authorization response code" },
        "CardholderText": { "type": "string", "description": "Text to be shown to cardholder" },
        "AttendantText": { "type": "string", "description": "Text to be shown to attendant" },
        "IssCntryC": { "type": "integer", "description": "Issuer country code" },
        "POSEntryMode": { "$ref": "#/$defs/POSEntryMode" },
        "TrxCurrC": { "$ref": "#/$defs/CurrencyCode" },
        "TrxType": { "type": "integer", "description": "ISO 8583 transaction type" },
